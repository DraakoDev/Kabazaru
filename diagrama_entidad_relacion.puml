@startuml


entity Vehiculo {
  numeroBastidor <<PK>>
  Modelo
  Precio
}

entity Descuento { 
  Id
  Porcentaje
  Descripcion
}

entity Marca {
  Nombre <<PK>>
}

entity Modelo {
  Nombre <<PK>>
  Marca
}

entity Equipaje {
  Modelo 
  Accesorio
  Extra
  Precio
}

entity StockConsesionario {
  Modelo 
  Cantidad
  Consesionario 
}

entity StockServicioOficial {
  Modelo
  Cantidad
  ServicioOficial
}

entity Vendedor {
  Cedula
  Nombre
  Domicilio
  Correo
  Empresa
}

entity Venta {
  Vendedor
  DetalleVenta
}

entity DetalleVenta {
  Vehiculo 
  Precio
  MetodoPago
  FechaEntrega
  Matricula
  Encargo
}

entity DescuentoVehiculo {
  Vehiculo 
  Descuento 
}

entity FichaTecnica {
  Modelo 
  Cilindrada
  Potencia
  Motor
  Combustible
  Carroceria
  Color
}

entity Empresa {
  NIF
  Nombre
  Direccion
  Tipo 
}

entity Consesionario {
  Empresa <<FK>>
}

entity Servicio {
  Empresa <<FK>>
}

hide methods

Vendedor -- Venta : (1,N)
Venta -- DetalleVenta : (1,N)
Consesionario -- Marca : (1,N)
Servicio -- Marca : (1,N)
Empresa -- Vendedor : (1,N)
Empresa -- Consesionario : (1,N)
Empresa -- Servicio : (1,N)
Vehiculo -- DescuentoVehiculo : (1,N)
Descuento -- DescuentoVehiculo : (1,N)
Modelo -- Vehiculo : (1,N)
Marca -- Modelo : (1,N)
Modelo -- Equipaje : (1,N)
Modelo -- FichaTecnica : (1,1)
Modelo -- StockConsesionario : (1,N)
Modelo -- StockServicioOficial : (1,N)

@enduml
