@startuml DiagramaEntidadRelacion

skinparam linetype ortho

together {
  entity Empresa
  entity TipoEmpresa
}

together {
  entity Persona
  entity Usuario
  entity TipoUsuario
  entity Vendedor
  entity Cliente
}

together {
  entity Marca
  entity Modelo
  entity FichaTecnica
  entity Equipaje
  entity Accesorio
}

entity Persona {
  Cedula <<PK>>
  Nombre
  Domicilio
  Correo
}

entity Usuario {
  Persona <<PK, FK>>
  Nombre
  Clave
}

entity TipoUsuario {
  Usuario <<PK>>
  Tipo
}

entity Vendedor {
  Persona <<PK, FK>>
  Empresa <<FK>>
}

entity Cliente {
  Persona <<PK, FK>>
  UltimaCompra
}

entity Stock{
  Modelo <<PK, FK>>
  Empresa <<PK, FK>>
  Cantidad  
}

entity Automovil {
  numeroBastidor <<PK>>
  Modelo <<FK>>
  Precio
  Estado
}

entity Descuento { 
  Id <<PK>>
  Porcentaje
  Descripcion
  FechaFin
  Estado
}

entity Marca {
  Nombre <<PK>>
}

entity Modelo {
  Id <<PK>>
  Marca <<FK>> 
  Nombre <<UNIQUE>>
}

entity Equipaje {
  Id <<PK>>
  Modelo <<FK>>
  Accesorio <<FK>>
  EsExtra
}

entity Venta {
  Id <<PK>>
  Vendedor <<FK>>
  Cliente <<FK>>
  Automovil <<FK, UNIQUE>>
  FechaEntrega
  FechaVenta
  Matricula
  Encargo
}

entity Factura {
  Id <<PK>>
  Venta <<FK>>
  PrecioAutomovil
  Total
  FechaEmision
  MetodoPago
}

entity Accesorio {
  Id <<PK>>
  Nombre
  Precio
}

entity ExtrasAplicados {
  Factura <<PK, FK>>
  Equipaje <<PK, FK>>
  Precio
}

entity DescuentoAplicado {
  Factura <<PK, FK>>
  Descuento <<PK, FK>>
  Porcentaje
}

entity FichaTecnica {
  Modelo <<PK FK>>
  Cilindrada
  Potencia
  Motor
  Combustible
  Carroceria
  Color
}

entity Empresa {
  NIF <<PK>>
  Nombre
  Direccion
}

entity TipoEmpresa {
  Empresa <<PK>>
  Tipo
}

entity MarcaEmpresa {
   Empresa <<PK, FK>>
   Marca <<PK, FK>>
}

entity DescuentoAutomovil {
  Automovil <<PK, FK>>
  Descuento <<PK, FK>>
}

hide methods

Empresa ||--|{ Stock
Empresa |o--{ Vendedor
Empresa ||--|| TipoEmpresa
Empresa ||--{ MarcaEmpresa
Stock }|--|| Modelo
Automovil -- Venta: (0,1)
Automovil -- Modelo: (N,1)
Modelo -- Equipaje: (1,N)
Modelo -- FichaTecnica: (1,1)
Vendedor -- Venta: (0,N)
MarcaEmpresa }--|| Marca
Marca -- Modelo: (1,N)
Factura -- Venta: (1,1)
Factura -- ExtrasAplicados: (0,N)
Equipaje -- ExtrasAplicados: (0,N)
DescuentoAplicado -- Factura: (0,N)
DescuentoAplicado -- Descuento: (0,N)
DescuentoAutomovil -- Automovil: (0,N)
DescuentoAutomovil -- Descuento: (0,N)
Persona }o--|| Usuario
Usuario ||--|| TipoUsuario
Persona -- Vendedor: (0,1)
Persona -- Cliente: (0,1)
Venta -- Cliente: (1,1)
Accesorio -- Equipaje: (1,N)

@enduml
