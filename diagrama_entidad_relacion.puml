@startchen Consesionario de Autos

entity Vehiculo {
  numeroBastidor
  Marca
  Modelo
  Precio
  Descuento
}

entity Descuento {
  Vehiculo
  Descuento
}

entity Descuento { 
  Descuento

}

entity Marca {
  Nombre <<key>>
}

entity Modelo {
  Nombre <<key>>
  Marca
}

entity Equipaje {
  Modelo
  Accesorio
  Extra
  Precio
}

@endchen
